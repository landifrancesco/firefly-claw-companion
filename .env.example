TZ=Europe/Rome

# Docker/network layout
# Firefly URL examples:
# - same Docker host: http://firefly:8080
# - remote VPS / public HTTPS: https://firefly.example.com
FIREFLY_DOCKER_NETWORK=firefly
FIREFLY_DOCKER_NETWORK_EXTERNAL=false
FIREFLY_BASE_URL=http://firefly:8080
FIREFLY_API_BASE_PATH=/api/v1
OPENCLAW_PORT=18789
OPENCLAW_BIND=loopback
OPENCLAW_HEALTHCHECK_INTERVAL=30s
OPENCLAW_HEALTHCHECK_TIMEOUT=15s
OPENCLAW_HEALTHCHECK_RETRIES=8
OPENCLAW_HEALTHCHECK_START_PERIOD=120s

# OpenClaw runtime defaults
OPENCLAW_DEFAULT_MODEL=openai/gpt-5.4-mini
FIREFLY_TIMEOUT_SECONDS=15
FIREFLY_REQUEST_RETRIES=2
FIREFLY_RETRY_BACKOFF_SECONDS=0.5
FIREFLY_VERIFY_TLS=true
FIREFLY_FORCE_CONNECTION_CLOSE=true
FIREFLY_DEFAULT_DRY_RUN=true
FIREFLY_HIGH_VALUE_THRESHOLD=250.00
FIREFLY_DEDUPE_WINDOW_DAYS=7
FIREFLY_ALLOW_DELETE=false
FIREFLY_RUNTIME_VERIFY_ON_BOOT=true
FIREFLY_ACCESS_TOKEN_EXPIRES_ON=
FIREFLY_TOKEN_REMINDER_DAYS=60,30,14,7,3,1
FIREFLY_TOKEN_REMINDER_CHECK_INTERVAL_SECONDS=21600
FIREFLY_MAPPINGS_PATH=/home/openclaw/workspace/config/mappings.yml
FIREFLY_POLICY_PATH=/home/openclaw/workspace/config/policy.yml
TELEGRAM_ENABLED=true
TELEGRAM_OWNER_ID=
TELEGRAM_TARGET_ID=
TELEGRAM_DM_POLICY=allowlist
FIREFLY_CHAT_LANGUAGE=auto
FIREFLY_RECEIPT_AI_OCR=true
FIREFLY_PDF_OCR_PROVIDER_ENABLED=true
PDFAPIHUB_API_KEY=
PDFAPIHUB_BASE_URL=https://pdfapihub.com/api
FIREFLY_PDF_OCR_LANG=ita+eng
OPENCLAW_TELEGRAM_CHANNEL_ENABLED=false

# Optional model provider credentials understood directly by OpenClaw.
# Set only the providers you actually use.
OPENAI_API_KEY=
OPENAI_API_KEYS=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=
AI_GATEWAY_API_KEY=

# Optional local testing profile for docker-compose.example-firefly.yml
EXAMPLE_FIREFLY_APP_URL=http://localhost:8080
EXAMPLE_FIREFLY_DB_NAME=firefly
EXAMPLE_FIREFLY_DB_USER=firefly
EXAMPLE_FIREFLY_DB_PASSWORD=firefly-change-me
EXAMPLE_FIREFLY_SITE_OWNER=owner@example.test
